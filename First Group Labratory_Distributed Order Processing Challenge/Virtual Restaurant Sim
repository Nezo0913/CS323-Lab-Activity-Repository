from mpi4py import MPI
from multiprocessing import Lock
import time
import random

comm = MPI.COMM_WORLD
rank = comm.Get_rank()
size = comm.Get_size()

# Shared memory (master only usage conceptually)
shared_orders = []
lock = Lock()

if rank == 0:
    print(f"[MASTER] Running with {size} processes\n")

    # INPUT VALIDATION
    while True:
        try:
            num_orders = int(input("Enter number of orders (8 max): "))
            if 1 <= num_orders <= 8:
                break
            else:
                print("Please enter a number between 1 and 8.")
        except ValueError:
            print("Invalid input. Please enter a number.")

    orders = []
    for i in range(num_orders):
        while True:
            item = input(f"Order {i+1} name: ").strip()
            if item:
                break
            print("Item name cannot be empty.")
        orders.append({"id": i + 1, "item": item})

    print("\n[MASTER] Generated Orders:")
    for o in orders:
        print(o)

    print("\n[MASTER] Distributing orders...\n")

    # DISTRIBUTE TASKS
    num_workers = size - 1
    for i, order in enumerate(orders):
        worker = (i % num_workers) + 1
        comm.send(order, dest=worker)

    # TERMINATION SIGNAL
    for w in range(1, size):
        comm.send(None, dest=w)

    # COLLECT RESULTS
    for _ in range(num_orders):
        result = comm.recv(source=MPI.ANY_SOURCE)

        with lock:
            shared_orders.append(result)

    # FINAL OUTPUT
    print("\n[MASTER] Completed Orders (Shared Memory):")
    for r in shared_orders:
        print(r)

# WORKERS
else:
 #3
    while True:
        # Receive order from master
        order = comm.recv(source=0)

        # Check for termination signal
        if order is None:
            break

        print(f"[Worker {rank}] Processing {order}")

        # Simulate processing delay
        time.sleep(random.uniform(1, 3))

        # Create result dictionary
        result = {
            "order_id": order["id"],
            "item": order["item"],
            "processed_by": rank
        }

        # Send result back to master
        comm.send(result, dest=0)
        print(f"[Worker {rank}] Finished Order {order['id']}")
