import random
import time

# Dataset Sizes per instructions
SMALL = 1000
MEDIUM = 100000
LARGE = 1000000

def generate_data(size, special_case=None):
    data = [random.randint(1, 1000000) for _ in range(size)]
    if special_case == "sorted":
        data.sort()
    elif special_case == "reverse":
        data.sort(reverse=True)
    return data
def sequential_linear_search(data, target):
    """
    Step-by-step search through the list.
    Returns the index if found, else -1.
    """
    for i in range(len(data)):
        if data[i] == target:
            return i  # Found it!
    return -1  # Not found