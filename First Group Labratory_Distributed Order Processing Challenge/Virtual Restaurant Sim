from mpi4py import MPI
import time
import random

comm = MPI.COMM_WORLD
rank = comm.Get_rank()
size = comm.Get_size()



# MASTER PROCESS
if rank == 0:
    print(f"[MASTER] Running with {size} processes\n")

    # Generate orders (no shared memory needed)
    orders = [
        {"id": i, "item": random.choice(["Rib Steak", "Wine", "Pasta", "Mutton Chop", "Szechuan Beef Tripe"])}
        for i in range(1, 7)
    ]

    print("[MASTER] Generated Orders:")
    for o in orders:
        print(o)

    print("\n[MASTER] Distributing orders...\n")

    # DISTRIBUTE TASKS
    num_workers = size - 1
    for i, order in enumerate(orders):
        worker = (i % num_workers) + 1
        comm.send(order, dest=worker)

    # TERMINATION SIGNAL
    for w in range(1, size):
        comm.send(None, dest=w)

