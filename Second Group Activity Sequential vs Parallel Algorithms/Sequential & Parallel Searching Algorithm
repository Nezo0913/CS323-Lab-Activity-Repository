import random
import time
from multiprocessing import Process, Queue

# Dataset Sizes per instructions
SMALL = 1000
MEDIUM = 100000
LARGE = 1000000

def generate_data(size, special_case=None):
    data = [random.randint(1, 1000000) for _ in range(size)]
    if special_case == "sorted":
        data.sort()
    elif special_case == "reverse":
        data.sort(reverse=True)
    return data

def sequential_linear_search(data, target):
    """
    Step-by-step search through the list.
    Returns the index if found, else -1.
    """
    for i in range(len(data)):
        if data[i] == target:
            return i  # Found it!
    return -1  # Not found

# Worker for Parallel Search
def worker(sub_data, target, q, offset):
    for i, v in enumerate(sub_data):
        if v == target:
            return q.put(i + offset)
    q.put(-1)

def parallel_linear_search(data, target, num_processes=4):
    q = Queue()
    processes = []

    chunk_size = len(data) // num_processes

    for i in range(num_processes):
        start = i * chunk_size
        end = (i + 1) * chunk_size if i != num_processes - 1 else len(data)

        sub_data = data[start:end]

        p = Process(target=worker, args=(sub_data, target, q, start))
        processes.append(p)
        p.start()

    results = []
    for _ in processes:
        results.append(q.get())

    for p in processes:
        p.join()

    # Get valid result (smallest index if multiple found)
    valid_results = [r for r in results if r != -1]
    return min(valid_results) if valid_results else -1


def run_tests():
   for size in [SMALL, MEDIUM, LARGE]:
        print(f"Dataset size: {size}")

        data = generate_data(size)
        target = data[-1]  # Worst case

# Sequential Test
        start = time.time()
        seq_result = sequential_linear_search(data, target)
        end = time.time()
        seq_time = end - start

        print(f"Sequential Result: {seq_result}")
        print(f"Sequential Time: {seq_time:.6f} seconds")

        # Parallel Test
        start = time.time()
        par_result = parallel_linear_search(data, target)
        end = time.time()
        par_time = end - start

        print(f"Parallel Result: {par_result}")
        print(f"Parallel Time: {par_time:.6f} seconds")


      # Comparison
        if par_time < seq_time:
            print("Parallel was faster")
        else:
            print("Sequential was faster")

if __name__ == "__main__":
    run_tests()
